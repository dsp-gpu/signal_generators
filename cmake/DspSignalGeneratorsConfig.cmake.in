@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(DspCore     REQUIRED)
find_dependency(DspSpectrum REQUIRED)
find_dependency(hip         REQUIRED)   # lowercase — Linux case-sensitive!

include("${CMAKE_CURRENT_LIST_DIR}/DspSignalGeneratorsTargets.cmake")
check_required_components(DspSignalGenerators)
